# Discord Developer Portal에서 발급받은 봇 토큰입니다. 실제 값을 저장하거나 커밋하지 마세요.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# 개발 서버에 명령어를 즉시 등록하려면 Guild ID를 설정하세요.
DISCORD_GUILD_ID=
# Fine-grained PAT 또는 GitHub App installation token (읽기 권한만)
GITHUB_TOKEN=
# /fix-issue 실제 변경 워커는 기본 비활성화입니다. 쓰기 토큰과 정확한 허용 저장소를 설정해야 합니다.
GITHUB_WRITE_TOKEN=
FIX_WORKER_ENABLED=false
FIX_PUSH_ENABLED=false
FIX_ALLOWED_REPOSITORIES=
FIX_WORKSPACE_ROOT=/tmp/discord-github-bot-tasks
FIX_TASK_TIMEOUT_MINUTES=20
FIX_SECOND_APPROVAL_TTL_MINUTES=15
FIX_MAX_FILES=10
FIX_MAX_NEW_FILES=3
FIX_MAX_CHANGED_LINES=1000
FIX_MAX_FILE_CHANGED_LINES=400
FIX_ALLOW_DEPENDENCY_INSTALL=false
GIT_BOT_NAME=
GIT_BOT_EMAIL=
DATABASE_URL=file:./data/pachub.sqlite
# AI는 기본적으로 비활성화됩니다. OpenAI 호환 API 사용 시 아래 값을 모두 설정하세요.
AI_PROVIDER=none
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
NODE_ENV=development
LOG_LEVEL=info
